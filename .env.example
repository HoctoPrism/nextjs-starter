# SQLite database file path (prefixed with file:). Created automatically.
DATABASE_URL=file:./data/dev.db

# Auth.js v5 — generate with: openssl rand -base64 32
AUTH_SECRET=change-me-in-production
AUTH_URL=http://localhost:3000

# Set to 1 to trust the host header (required behind proxies in Auth.js v5)
AUTH_TRUST_HOST=1
